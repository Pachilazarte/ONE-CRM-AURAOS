# ── Instagram Credentials ────────────────────
IG_BURNER_USER=
IG_BURNER_PASS=

# ── App Configuration ────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── Database (Supabase) ──────────────────────
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Redis (Task Queue) ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (Resend) ───────────────────────────
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# ── Scraping Settings ────────────────────────
HEADLESS=true
MAX_CONCURRENCY=1

# ── Residential Proxy (REQUIRED for Instagram — datacenter IPs are blocked) ──
# Providers: SmartProxy (gate.smartproxy.com:7000), BrightData (zproxy.lum-superproxy.io:22225), Oxylabs (pr.oxylabs.io:7777)
PROXY_HOST=gate.smartproxy.com
PROXY_PORT=7000
PROXY_USER=
PROXY_PASS=
